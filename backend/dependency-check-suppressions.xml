<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    
    <!-- Suppress false positives for well-known libraries -->
    <suppress>
        <notes><![CDATA[
        Spring Boot libraries are regularly updated and monitored for security issues.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/.*$</packageUrl>
        <cve>CVE-2016-1000027</cve>
    </suppress>
    
    <!-- Example suppression for development dependencies -->
    <suppress>
        <notes><![CDATA[
        Test dependencies are not deployed to production
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.hamcrest/.*$</packageUrl>
        <cve>CVE-2020-15250</cve>
    </suppress>

</suppressions>
