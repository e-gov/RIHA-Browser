<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration>
<configuration>
    <property name="LOG_DIR" value="/var/log"/>
    <property name="appName" value="riha-browser"/>
    
    <!-- Console appender for development -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <appender name="FILEJSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${appName}/${appName}.json.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${appName}/${appName}.%d{yyyy-MM-dd}.%i.json.log</fileNamePattern>
            <maxHistory>14</maxHistory>
            <maxFileSize>100MB</maxFileSize>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>
    
    <appender name="AUDIT_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${appName}/${appName}-audit.json.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${appName}/${appName}-audit.%d{yyyy-MM-dd}.%i.json.log</fileNamePattern>
            <maxHistory>14</maxHistory>
            <maxFileSize>100MB</maxFileSize>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>
    
    <!-- Spring Security logging (additivity=false to prevent duplication) -->
    <logger name="org.springframework.security" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILEJSON"/>
    </logger>
    
    <!-- Our application logging (additivity=false to prevent duplication) -->
    <logger name="ee.ria.riha" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILEJSON"/>
    </logger>
    
    <!-- Audit logging (separate from main logs) -->
    <logger name="ee.ria.riha.logging.auditlog" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_LOG"/>
    </logger>
    
    <!-- Validator logging -->
    <logger name="Validator" level="INFO" additivity="false">
        <appender-ref ref="FILEJSON"/>
    </logger>
    
    <!-- Handler mapping logging -->
    <logger name="_org.springframework.web.servlet.HandlerMapping.Mappings" level="INFO" additivity="false">
        <appender-ref ref="FILEJSON"/>
    </logger>
    
    <!-- Root logger for everything else -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILEJSON"/>
    </root>
</configuration>
