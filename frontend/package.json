{
  "name": "riha",
  "version": "8.0.3",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "npm run prettier:check && npm run lint",
    "build": "npm run prebuild && ng build",
    "build-production": "npm run prebuild && ng build --configuration production --verbose --aot=true",
    "e2e": "ng e2e",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "local": "ng serve -c local",
    "ng": "ng",
    "prettier:check": "prettier --check \"{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,html,cjs,mjs,js,ts,tsx,css,scss}\"",
    "prettier:format": "prettier --write \"{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,html,cjs,mjs,js,ts,tsx,css,scss}\"",
    "start": "ng serve",
    "static": "static ../main/resources --port 8085",
    "test": "ng test --watch=false",
    "test-watcher": "ng test"
  },
  "dependencies": {
    "@angular/animations": "^20.1.7",
    "@angular/cdk": "^20.1.5",
    "@angular/common": "^20.1.7",
    "@angular/compiler": "^20.1.7",
    "@angular/core": "^20.1.7",
    "@angular/forms": "^20.1.7",
    "@angular/localize": "^20.1.7",
    "@angular/material": "^20.1.5",
    "@angular/platform-browser": "^20.1.7",
    "@angular/platform-browser-dynamic": "^20.1.7",
    "@angular/platform-server": "^20.3.21",
    "@angular/router": "^20.1.7",
    "@narik/custom-validators": "14.0.0",
    "@ng-bootstrap/ng-bootstrap": "^19.0.1",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.7",
    "core-js": "^3.45.0",
    "enhanced-resolve": "^5.18.3",
    "font-awesome": "^4.7.0",
    "jquery": "^3.7.1",
    "linkify-string": "^4.3.2",
    "linkifyjs": "~4.3.2",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "ng-recaptcha-2": "^16.0.1",
    "ngx-toastr": "19.0.0",
    "ngx-ui-switch": "^16.1.0",
    "poor-mans-proxy": "1.0.0",
    "popper.js": "^1.16.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "update-check": "^1.5.4",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^20.0.0",
    "@angular-devkit/build-angular": "^20.1.6",
    "@angular-eslint/builder": "^20.1.1",
    "@angular-eslint/eslint-plugin": "^20.1.1",
    "@angular-eslint/eslint-plugin-template": "^20.1.1",
    "@angular-eslint/schematics": "^20.1.1",
    "@angular-eslint/template-parser": "^20.1.1",
    "@angular/cli": "20.1.6",
    "@angular/compiler-cli": "20.1.7",
    "@types/jasmine": "^5.1.8",
    "@types/node": "^24.2.1",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@typescript-eslint/types": "^8.40.0",
    "@typescript-eslint/utils": "^8.40.0",
    "eslint": "^9.33.0",
    "jasmine-core": "~5.9.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-cli": "~2.0.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "node-static": "^0.7.11",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "protractor": "~7.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.2"
  },
  "packageManager": "yarn@4.9.2"
}
